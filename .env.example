# === DART API ===
DART_API_KEY=your_dart_api_key_here

# === FnGuide Credentials ===
FNGUIDE_ID=your_fnguide_id
FNGUIDE_PW=your_fnguide_password

# === DART Collection Settings ===
DART_START_DATE=20200101
DART_KEYWORDS=사업보고서;분기보고서;반기보고서;단일판매ㆍ공급계약체결;주요사항보고서;전환청구권;신주인수권;교환청구권;매출액또는손익구조;재무제표기준영업(잠정)실적;증권신고서;신규시설투자등;감사보고서

# === News Collection ===
NEWS_DAYS_BACK=90

# === OpenAI / LLM ===
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.4-mini

# === Gemini (optional, overrides OpenAI when set) ===
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# === Paths ===
STOCKS_JSON=./stocks.json
STOCKS_BASE_DIR=./stocks
OUTPUT_DIR=./stocks
OBSIDIAN_INBOX=

# === Request Settings ===
REQUEST_DELAY=1.0
REQUEST_TIMEOUT=30
